# LiteLLM BYO gateway environment — copy to .env and fill in.
# The api_base must point at the Foundry account's azure_ai inference root:
#   https://<account-name>.services.ai.azure.com/models
# Get the values from the Bicep deployment outputs (foundryAccounts[].endpoint)
# and from `az cognitiveservices account keys list`.

FOUNDRY1_API_BASE=https://foundry1-xxxxxx.services.ai.azure.com/models
FOUNDRY1_API_KEY=<foundry1-key>

FOUNDRY2_API_BASE=https://foundry2-xxxxxx.services.ai.azure.com/models
FOUNDRY2_API_KEY=<foundry2-key>

# Virtual key clients present to the LiteLLM proxy (choose any strong value).
LITELLM_MASTER_KEY=sk-litellm-local-poc
