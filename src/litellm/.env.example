# LiteLLM BYO gateway environment — copy to .env and fill in.
#
# The lab's Foundry accounts have local (API-key) auth DISABLED, so LiteLLM authenticates
# with Microsoft Entra ID (no keys). Two values are dynamic:
#   - api_base: the account's Azure OpenAI endpoint (https://<account>.openai.azure.com/)
#   - AZURE_AD_TOKEN: a short-lived Entra ID token for the Cognitive Services audience.
#
# Get the endpoints from the Bicep deployment outputs (or `az cognitiveservices account show`),
# then mint a token (valid ~1 hour) with:
#   az account get-access-token --resource https://cognitiveservices.azure.com --query accessToken -o tsv

FOUNDRY1_API_BASE=https://foundry1-xxxxxx.openai.azure.com/
FOUNDRY2_API_BASE=https://foundry2-xxxxxx.openai.azure.com/
AZURE_API_VERSION=2024-10-21

# Paste the token from the az command above (refresh it when it expires).
AZURE_AD_TOKEN=<entra-id-access-token>

# Virtual key clients present to the LiteLLM proxy (choose any strong value).
LITELLM_MASTER_KEY=sk-litellm-local-poc
