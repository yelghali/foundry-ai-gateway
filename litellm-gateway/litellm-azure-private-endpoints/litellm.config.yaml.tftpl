model_list:
  - model_name: ${public_model_name}
    litellm_params:
      model: azure/${deployment_name}
      api_base: os.environ/FOUNDRY1_API_BASE
      api_version: os.environ/AZURE_API_VERSION
    model_info:
      mode: chat
  - model_name: ${secondary_model_name}
    litellm_params:
      model: azure/${deployment_name}
      api_base: os.environ/FOUNDRY2_API_BASE
      api_version: os.environ/AZURE_API_VERSION
    model_info:
      mode: chat

litellm_settings:
  enable_azure_ad_token_refresh: true
  store_model_in_db: ${store_model_in_db}
%{ if spend_logs_retention != "" ~}

general_settings:
  # Auto-purge usage/spend logs from PostgreSQL after this window. Only request
  # metadata is logged (no prompt/response content unless explicitly enabled).
  maximum_spend_logs_retention_period: "${spend_logs_retention}"
%{ endif ~}

router_settings:
  routing_strategy: simple-shuffle
  num_retries: 2
  cooldown_time: 30
%{ if prefer_primary_region ~}
  # Primary/fallback routing: FOUNDRY1 (the first foundry_regions entry, e.g.
  # France Central) serves ALL traffic; requests fail over to FOUNDRY2 only on
  # error / timeout / 429. This also keeps the primary warm (no cold-start
  # latency from an idle region). Set prefer_primary_region = false to instead
  # load-balance (simple-shuffle) evenly across both regions.
  fallbacks: [{ "${public_model_name}": ["${secondary_model_name}"] }]
%{ endif ~}
%{ if redis_enabled ~}
  # Shared router state across replicas (cooldowns, rate-limits, usage) so load
  # balancing + 429 failover stay correct when running >1 LiteLLM replica.
  redis_host: os.environ/REDIS_HOST
  redis_port: os.environ/REDIS_PORT
  redis_password: os.environ/REDIS_PASSWORD
%{ endif ~}
