# App-only deploy on existing infra. Choose ONE way to reference the infra
# (set infra_state_backend accordingly):
#
# A) LOCAL state file (default): infra_state_backend = "local" + infra_state_path.
#    Everything below is read automatically — leave it commented out.
#
# B) REMOTE state in an Azure Storage blob: infra_state_backend = "azurerm" +
#    infra_state_config (see the block below).
#
# C) NO state (env vars / explicit values): infra_state_backend = "none" and
#    provide the values below (or via TF_VAR_* env vars).

subscription_id = "00000000-0000-0000-0000-000000000000"

# --- Option A: read from a LOCAL infra state file (default) -------------------
infra_state_backend = "local"
infra_state_path    = "../terraform-litellm/terraform.tfstate"

# --- Option B: read from REMOTE infra state (Azure Storage blob) --------------
# infra_state_backend = "azurerm"
# infra_state_config = {
#   resource_group_name  = "rg-tfstate"
#   storage_account_name = "sttfstate12345"
#   container_name       = "tfstate"
#   key                  = "litellm-infra.tfstate"
#   # use_azuread_auth   = "true"   # auth with your Entra login instead of a storage key
# }

# --- Option C: no state; provide infra references explicitly ------------------
# infra_state_backend          = "none"
# resource_group_name          = "rg-litellm-gateway"
# location                     = "eastus2"
# container_app_name           = "ca-litellm"
# container_app_environment_id = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.App/managedEnvironments/<env>"
# identity_id                  = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.ManagedIdentity/userAssignedIdentities/<id>"
# identity_client_id           = "<client-guid>"
# master_key_secret_uri        = "https://<kv>.vault.azure.net/secrets/litellm-master-key"
# database_url_secret_uri      = "https://<kv>.vault.azure.net/secrets/database-url"
# foundry_api_bases            = ["https://<f1>.openai.azure.com/", "https://<f2>.openai.azure.com/"]
# api_version                  = "2024-10-21"
# model_deployment_name        = "gpt-4.1"
# public_model_name            = "gpt-4.1"
# litellm_master_key           = "<only needed for test/key scripts>"
